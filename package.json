{
	"name": "my-links",
	"version": "4.3.4",
	"type": "module",
	"license": "GPL-3.0-only",
	"scripts": {
		"start": "node bin/server.js",
		"build": "node ace build",
		"dev": "node ace serve --hmr",
		"test": "node ace test",
		"lint": "eslint . --report-unused-disable-directives --max-warnings 0 --ignore-pattern '.adonisjs/*'",
		"format": "prettier --write --parser typescript '**/*.{ts,tsx}'",
		"typecheck": "tsc --noEmit",
		"check": "pnpm run lint && pnpm run typecheck",
		"prepare": "husky",
		"release": "release-it",
		"tuyau": "node ace tuyau:generate",
		"extract": "lingui extract --clean",
		"compile": "lingui compile --typescript"
	},
	"imports": {
		"#adonis/api": "./.adonisjs/api.ts",
		"#config/*": "./config/*.js",
		"#controllers/*": "./app/controllers/*.js",
		"#generated/*": "./.adonisjs/server/*.js",
		"#models/*": "./app/models/*.js",
		"#routes/*": "./app/routes/*.js",
		"#services/*": "./app/services/*.js",
		"#transformers/*": "./app/transformers/*.js",
		"#validators/*": "./app/validators/*.js",
		"#middleware/*": "./app/middleware/*.js",
		"#enums/*": "./app/enums/*.js",
		"#types/*": "./app/types/*.js",
		"#exceptions/*": "./app/exceptions/*.js",
		"#lib/*": "./app/lib/*.js",
		"#constants/*": "./app/constants/*.js",
		"#providers/*": "./providers/*.js",
		"#database/*": "./database/*.js",
		"#tests/*": "./tests/*.js",
		"#start/*": "./start/*.js"
	},
	"devDependencies": {
		"@adonisjs/assembler": "^8.0.1",
		"@adonisjs/eslint-config": "3.0.0",
		"@adonisjs/prettier-config": "^1.4.5",
		"@adonisjs/tsconfig": "^2.0.0",
		"@faker-js/faker": "^10.3.0",
		"@japa/assert": "^4.2.0",
		"@japa/plugin-adonisjs": "^5.1.0",
		"@japa/runner": "^5.3.0",
		"@lingui/babel-plugin-lingui-macro": "^5.9.3",
		"@lingui/cli": "^5.9.3",
		"@lingui/vite-plugin": "^5.9.3",
		"@poppinss/ts-exec": "^1.4.4",
		"@release-it/conventional-changelog": "^10.0.6",
		"@tuyau/utils": "^0.0.9",
		"@types/luxon": "^3.7.1",
		"@types/node": "^24.10.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript-eslint/eslint-plugin": "^8.57.0",
		"@unocss/preset-icons": "^66.6.6",
		"@unocss/preset-web-fonts": "^66.6.6",
		"@vitejs/plugin-react": "^5.1.4",
		"babel-plugin-macros": "^3.1.0",
		"eslint": "^10.0.3",
		"eslint-plugin-lingui": "^0.11.0",
		"hot-hook": "^1.0.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"pino-pretty": "^13.1.3",
		"prettier": "^3.8.1",
		"release-it": "^19.2.4",
		"typescript": "~5.9.3",
		"unocss": "^66.6.6",
		"vite": "^7.3.1",
		"youch": "^4.1.0"
	},
	"dependencies": {
		"@adonisjs/ally": "^6.0.0",
		"@adonisjs/auth": "^10.0.0",
		"@adonisjs/core": "^7.0.1",
		"@adonisjs/cors": "^3.0.0",
		"@adonisjs/inertia": "^4.1.0",
		"@adonisjs/lucid": "^22.1.1",
		"@adonisjs/session": "^8.0.0",
		"@adonisjs/shield": "^9.0.0",
		"@adonisjs/static": "^2.0.1",
		"@adonisjs/vite": "^5.1.0",
		"@inertiajs/react": "^2.3.18",
		"@lingui/core": "^5.9.3",
		"@lingui/react": "^5.9.3",
		"@minimalstuff/ui": "^1.2.1",
		"@tuyau/client": "^0.2.10",
		"@tuyau/core": "^1.2.1",
		"@tuyau/inertia": "^0.0.15",
		"@types/proxy-addr": "^2.0.3",
		"@vinejs/vine": "^4.3.0",
		"bentocache": "^1.6.1",
		"clsx": "^2.1.1",
		"edge.js": "^6.5.0",
		"emoji-picker-react": "^4.18.0",
		"emoji-regex": "^10.6.0",
		"knex": "^3.1.0",
		"luxon": "^3.7.2",
		"node-html-parser": "^7.1.0",
		"pg": "^8.20.0",
		"proxy-addr": "^2.0.7",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"reflect-metadata": "^0.2.2",
		"ua-parser-js": "^2.0.9",
		"zustand": "^5.0.12"
	},
	"hotHook": {
		"boundaries": [
			"./app/controllers/**/*.ts",
			"./app/middleware/**/*.ts"
		]
	},
	"prettier": {
		"trailingComma": "es5",
		"semi": true,
		"singleQuote": true,
		"useTabs": true,
		"quoteProps": "as-needed",
		"bracketSpacing": true,
		"arrowParens": "always",
		"printWidth": 80
	},
	"lint-staged": {
		"*.js,*.ts,*.jsx,*.tsx": "eslint --cache --fix"
	},
	"volta": {
		"node": "24.14.0"
	}
}
