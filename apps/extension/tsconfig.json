{
  "extends": "plasmo/templates/tsconfig.base",
  "exclude": ["node_modules", "../webapp/build", "../webapp/node_modules"],
  "include": [
    ".plasmo/index.d.ts",
    "./**/*.ts",
    "./**/*.tsx",
    "../webapp/**/*.ts",
    "../webapp/.adonisjs/**/*.ts"
  ],
  "compilerOptions": {
    "paths": {
      "~*": ["./src/*"]
    },
    "baseUrl": ".",
    "experimentalDecorators": true,
    "moduleResolution": "bundler"
  }
}
